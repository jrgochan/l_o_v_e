FROM python:3.14-slim

WORKDIR /app

# Install system dependencies
# ffmpeg: audio processing
# libsndfile1: librosa dependency
# build-essential: compilation tools
# curl: healthcheck
RUN apt-get update && apt-get install -y --no-install-recommends \
  curl \
  ffmpeg \
  libsndfile1 \
  build-essential \
  cmake \
  ninja-build \
  && rm -rf /var/lib/apt/lists/*

# Install Python dependencies
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy application code
COPY app/ app/
# Assuming scripts folder might exist or needed, strictly copying app/ is safer if likely self-contained.
# But for listener, main.py is in app/ so we are good.

# Environment variables
ENV PYTHONUNBUFFERED=1

# Expose port (Listener uses 8002)
EXPOSE 8002

# Healthcheck
HEALTHCHECK --interval=30s --timeout=30s --start-period=10s --retries=3 \
  CMD curl -f http://localhost:8002/health || exit 1

# Command
CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8002"]
