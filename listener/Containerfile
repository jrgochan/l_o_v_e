# pin: python – https://hub.docker.com/_/python
FROM python:3.12.8-bookworm
# pin: uv – https://github.com/astral-sh/uv/pkgs/container/uv
COPY --from=ghcr.io/astral-sh/uv:0.5 /uv /bin/uv

WORKDIR /app

# Install system dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
  curl \
  ffmpeg \
  libsndfile1 \
  build-essential \
  cmake \
  ninja-build \
  && rm -rf /var/lib/apt/lists/*

# Enable bytecode compilation
ENV UV_COMPILE_BYTECODE=1
ENV UV_LINK_MODE=copy

# Install dependencies
COPY pyproject.toml uv.lock ./
RUN uv sync --frozen --no-install-project --no-dev --group listener

# Download the NLP model using uv pip directly
# Spacy's native downloader requires pip which isn't installed in our uv .venv
RUN uv pip install https://github.com/explosion/spacy-models/releases/download/en_core_web_sm-3.8.0/en_core_web_sm-3.8.0-py3-none-any.whl

# Copy application code
COPY listener/app/ app/
COPY infra/lib/python/ common/

# Environment variables
ENV PYTHONUNBUFFERED=1
ENV PYTHONPATH="/app:/app/common"
ENV PATH="/app/.venv/bin:$PATH"

# Expose port
EXPOSE 8002

# Healthcheck
HEALTHCHECK --interval=30s --timeout=30s --start-period=10s --retries=3 \
  CMD curl -f http://localhost:8002/health || exit 1

# Command
CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8002"]
