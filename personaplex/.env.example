# PersonaPlex Service Environment Configuration
# Copy to .env and fill in your values

# HuggingFace Token (required for model download)
# Get yours at: https://huggingface.co/settings/tokens
# You must accept the license at: https://huggingface.co/nvidia/personaplex-7b-v1
HF_TOKEN=your_huggingface_token_here

# Service Configuration
ENVIRONMENT=development
LOG_LEVEL=INFO
PORT=8003

# Compute Configuration
# Set to true to enable CPU offload (slower but works without GPU)
PERSONAPLEX_CPU_OFFLOAD=false

# CUDA Configuration (GPU only)
# Specify which GPU to use (0 = first GPU)
CUDA_VISIBLE_DEVICES=0
