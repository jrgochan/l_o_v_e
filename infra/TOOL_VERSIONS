# === Database & Infrastructure Tools ===
# Version strategy: Use latest available, validate against minimum requirements
# PostgreSQL - Version agnostic (auto-detects installed version)
POSTGRESQL_MIN_VERSION=18.0
POSTGRESQL_STRATEGY=version-agnostic
PGVECTOR_MIN_VERSION=0.5.0

# Redis - Version agnostic (use latest available)
REDIS_MIN_VERSION=6.0
REDIS_STRATEGY=version-agnostic

# Ollama - Always use latest
OLLAMA_STRATEGY=latest

# === Code Quality Thresholds ===
MAX_LINE_LENGTH=120
MAX_COMPLEXITY=15
COVERAGE_TARGET=100

# === Version File Format ===
# Lines starting with # are comments
# Format: KEY=VALUE (no spaces around =)
# Scripts parse this file to extract versions dynamically
