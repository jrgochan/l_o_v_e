---
# =============================================================================
# Tier 3 — Production (Live)
# =============================================================================
# COPY THIS FILE TO: group_vars/production/vars.yml
# AND EDIT WITH YOUR DETAILS.

deployment_tier: "production"

# --- Identity ---
domain_name: love.your-domain.com
admin_email: admin@your-domain.com
admin_password: "{{ vault_admin_password }}"

# --- Cloudflare Tunnel ---
# Get this token from Cloudflare Zero Trust Dashboard
cloudflare_tunnel_token: "{{ vault_cloudflare_tunnel_token }}"

# --- Database ---
db_user: love_user
db_password: "{{ vault_db_password }}"
db_name: love_db
force_db_reset: false
seed_level: "enhanced"
seed_dataset: "all"
seed_with_bootstrap: true

# --- Security ---
jwt_secret_key: "{{ vault_jwt_secret }}"

# --- Resource Scaling ---
uvicorn_workers_observer: 4
uvicorn_workers_default: 2

# --- PostgreSQL Tuning ---
postgres_shared_buffers: "4GB"
postgres_work_mem: "32MB"
postgres_maintenance_work_mem: "512MB"
postgres_effective_cache_size: "12GB"
postgres_max_connections: 200
postgres_wal_buffers: "64MB"

# --- Redis ---
redis_maxmemory: "1gb"

# --- Services ---
enable_ollama: true
enable_personaplex: "{{ gpu_available | default(false) }}"
enable_fail2ban: true
fail2ban_maxretry: 3
fail2ban_bantime: 3600

# --- SSL ---
ssl_mode: "letsencrypt"

# --- Logging ---
log_level: "WARNING"
