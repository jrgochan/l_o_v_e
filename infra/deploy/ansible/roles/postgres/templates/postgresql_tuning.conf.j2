# =============================================================================
# PostgreSQL Performance Tuning
# =============================================================================
# Generated by Ansible for tier: {{ deployment_tier | default('unknown') }}
# Applied on top of default postgresql.conf

# --- Memory ---
shared_buffers = {{ postgres_shared_buffers | default('512MB') }}
work_mem = {{ postgres_work_mem | default('4MB') }}
maintenance_work_mem = {{ postgres_maintenance_work_mem | default('128MB') }}
effective_cache_size = {{ postgres_effective_cache_size | default('1GB') }}

# --- Connections ---
max_connections = {{ postgres_max_connections | default(50) }}

# --- Write-Ahead Log ---
{% if postgres_wal_buffers is defined %}
wal_buffers = {{ postgres_wal_buffers }}
{% endif %}

# --- Logging ---
log_min_duration_statement = {% if deployment_tier | default('minimal') == 'production' %}1000{% elif deployment_tier | default('minimal') == 'staging' %}500{% else %}100{% endif %}

log_statement = {% if deployment_tier | default('minimal') == 'minimal' %}'all'{% else %}'ddl'{% endif %}
