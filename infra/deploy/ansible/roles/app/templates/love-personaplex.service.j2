[Unit]
Description=Love Stack - Personaplex API (Voice)
After=network.target postgresql-{{ postgresql_version }}.service redis.service

[Service]
User={{ app_user }}
Group={{ app_group }}
WorkingDirectory={{ app_dir }}/personaplex
ExecStart={{ app_dir }}/personaplex/.venv/bin/uvicorn app.main:app --host 0.0.0.0 --port {{ port_personaplex }} --workers {{ uvicorn_workers_default }}
Restart=always
EnvironmentFile={{ app_dir }}/infra/deploy/configs/env/production.env
# Enable fallback for PyTorch if MPS (Metal Performance Shaders) is not available
Environment=PYTORCH_ENABLE_MPS_FALLBACK=1

[Install]
WantedBy=multi-user.target
