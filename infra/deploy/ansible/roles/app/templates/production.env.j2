# =============================================================================
# L.O.V.E. Stack — Environment Configuration
# =============================================================================
# Generated by Ansible for tier: {{ deployment_tier | default('unknown') }}
# Do NOT edit manually — re-run the deploy playbook to update.

# General
APP_ENV=production
LOG_LEVEL={{ log_level | default('INFO') }}
DOMAIN_NAME={{ domain_name }}
PORT={{ port_frontend }}

# Security
SECRET_KEY={{ jwt_secret_key | default(lookup('password', '/dev/null chars=ascii_letters,digits length=64')) }}
ACCESS_TOKEN_EXPIRE_MINUTES=60
ALLOWED_ORIGINS=["https://{{ domain_name }}"]

# Admin & Registration
ADMIN_EMAIL={{ admin_email }}
ADMIN_PASSWORD={{ admin_password }}
REGISTRATION_ENABLED={{ registration_enabled | default(false) | bool }}

# Database
POSTGRES_USER={{ db_user }}
POSTGRES_PASSWORD={{ db_password }}
POSTGRES_DB={{ db_name }}
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Redis
REDIS_URL=redis://localhost:6379

# AI / Embeddings
AI_PROVIDER={{ ai_provider | default('ollama') }}
OLLAMA_BASE_URL={{ ollama_base_url | default('http://localhost:11434') }}
EMBEDDING_MODEL={{ embedding_model | default('all-MiniLM-L6-v2') }}

# Service URLs (Internal)
VERSOR_URL=http://localhost:{{ port_versor }}
OBSERVER_URL=http://localhost:{{ port_observer }}
LISTENER_URL=http://localhost:{{ port_listener }}

# Frontend Public URLs
{% if ssl_mode != 'none' %}
NEXT_PUBLIC_API_URL=https://{{ domain_name }}/api/observer
NEXT_PUBLIC_WS_URL=wss://{{ domain_name }}/api/observer
{% else %}
NEXT_PUBLIC_API_URL=http://{{ domain_name }}/api/observer
NEXT_PUBLIC_WS_URL=ws://{{ domain_name }}/api/observer
{% endif %}

# Deployment Metadata
DEPLOYMENT_TIER={{ deployment_tier | default('unknown') }}
