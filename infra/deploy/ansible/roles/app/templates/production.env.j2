# General
APP_ENV=production
LOG_LEVEL=INFO
DOMAIN_NAME={{ domain_name }}
PORT={{ port_frontend }}

# Security
SECRET_KEY={{ 'change-me-later' }}
ACCESS_TOKEN_EXPIRE_MINUTES=11520

# Database
POSTGRES_USER={{ db_user }}
POSTGRES_PASSWORD={{ db_password }}
POSTGRES_DB={{ db_name }}
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Redis
REDIS_URL=redis://localhost:6379

# AI / Embeddings
AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Service URLs (Internal)
VERSOR_URL=http://localhost:{{ port_versor }}
OBSERVER_URL=http://localhost:{{ port_observer }}
LISTENER_URL=http://localhost:{{ port_listener }}

# Frontend Public URLs
NEXT_PUBLIC_API_URL=https://{{ domain_name }}/api/observer
NEXT_PUBLIC_WS_URL=wss://{{ domain_name }}/api/observer
