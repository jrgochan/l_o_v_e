server {
    listen 80;
    server_name {{ domain_name }};

    # Cloudflare Tunnel connects to this local port.
    # SSL is terminated at Cloudflare Edge.
    # We trust the tunnel to be secure.

    # Security Headers
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-Frame-Options "DENY" always;
    add_header X-XSS-Protection "1; mode=block" always;
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;
    add_header Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; media-src 'self' blob:; worker-src 'self' blob:; connect-src 'self' https://{{ domain_name }} wss://{{ domain_name }};" always;

    # Frontend (Experience)
    location / {
        proxy_pass http://127.0.0.1:{{ port_frontend }};
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_cache_bypass $http_upgrade;
    }

    # Serve Next.js Static Files directly
    location /_next/static/ {
        alias {{ app_dir }}/experience/web/.next/static/;
        expires 365d;
        access_log off;
    }

    # API Proxy - Observer
    location /api/observer/ {
        proxy_pass http://127.0.0.1:{{ port_observer }}/;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_cache_bypass $http_upgrade;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # Keep WebSocket connections alive (default 60s would drop chat)
        proxy_read_timeout 86400s;
        proxy_send_timeout 86400s;
    }

    # API Proxy - Versor
    location /api/versor/ {
        proxy_pass http://127.0.0.1:{{ port_versor }}/;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_cache_bypass $http_upgrade;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # API Proxy - Listener
    location /api/listener/ {
        proxy_pass http://127.0.0.1:{{ port_listener }}/;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_cache_bypass $http_upgrade;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # Increase body size for audio uploads
        client_max_body_size 50M;
    }

    # Documentation (MkDocs static site)
    location /docs {
        alias {{ app_dir }}/docs-build;
        index index.html;
        try_files $uri $uri/ $uri/index.html =404;
    }
}
