server {
    listen 80;
    server_name {{ domain_name }};

    # Redirect HTTP to HTTPS (once SSL is set up)
    # return 301 https://$host$request_uri;

    # Frontend (Experience)
    location / {
        proxy_pass http://127.0.0.1:{{ port_frontend }};
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_cache_bypass $http_upgrade;
        proxy_cache_bypass $http_upgrade;
    }

    # Serve Next.js Static Files directly
    location /_next/static/ {
        alias {{ app_dir }}/experience/web/.next/static/;
        expires 365d;
        access_log off;
    }

    # API Proxy - Observer
    location /api/observer/ {
        proxy_pass http://127.0.0.1:{{ port_observer }}/;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_cache_bypass $http_upgrade;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # API Proxy - Versor
    location /api/versor/ {
        proxy_pass http://127.0.0.1:{{ port_versor }}/;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_cache_bypass $http_upgrade;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # API Proxy - Listener
    location /api/listener/ {
        proxy_pass http://127.0.0.1:{{ port_listener }}/;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_cache_bypass $http_upgrade;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        
        # Increase body size for audio uploads
        client_max_body_size 50M;
    }
}

server {
    listen 443 ssl http2;
    server_name {{ domain_name }};

    ssl_certificate /etc/nginx/ssl/server.crt;
    ssl_certificate_key /etc/nginx/ssl/server.key;
