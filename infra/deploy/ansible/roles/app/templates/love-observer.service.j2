[Unit]
Description=Love Stack - Observer API
After=network.target postgresql-15.service redis.service

[Service]
User={{ app_user }}
Group={{ app_group }}
WorkingDirectory={{ app_dir }}/observer
ExecStart={{ app_dir }}/observer/.venv/bin/uvicorn app.main:app --host 0.0.0.0 --port {{ port_observer }} --workers 4
Restart=always
EnvironmentFile={{ app_dir }}/infra/deploy/configs/env/production.env

[Install]
WantedBy=multi-user.target
