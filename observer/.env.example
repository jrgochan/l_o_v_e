# Observer Module - Environment Configuration
# Copy this file to .env and customize for your environment

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# PostgreSQL Connection
POSTGRES_USER=love_user
POSTGRES_PASSWORD=love_password
POSTGRES_DB=love_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Connection URL (auto-constructed if not provided)
# DATABASE_URL=postgresql+asyncpg://love_user:love_password@localhost:5432/love_db

# ============================================================================
# EMBEDDING SERVICE
# ============================================================================

# Provider: "local" or "openai"
EMBEDDING_PROVIDER=local

# Local Model (sentence-transformers)
EMBEDDING_MODEL=all-MiniLM-L6-v2
# Options: all-MiniLM-L6-v2 (fast, 384-dim)
#          all-mpnet-base-v2 (better quality, 768-dim)

# OpenAI (if using external provider)
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ============================================================================
# EXTERNAL SERVICES
# ============================================================================

# Versor API (for quaternion calculations)
VERSOR_URL=http://localhost:8001

# Listener API (for future integration)
LISTENER_URL=http://localhost:8002

# ============================================================================
# SECURITY
# ============================================================================

# Secret key for JWT tokens (generate with: openssl rand -hex 32)
SECRET_KEY=dev-secret-key-change-in-production

# CORS allowed origins (JSON array)
ALLOWED_ORIGINS=["http://localhost:3000", "http://localhost:19006"]

# ============================================================================
# PERFORMANCE TUNING
# ============================================================================

# HNSW search parameter (higher = better recall, slower queries)
HNSW_EF_SEARCH=40

# Database connection pool
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE=3600

# ============================================================================
# LOGGING & DEBUGGING
# ============================================================================

# Debug mode (true/false)
DEBUG=true

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=DEBUG

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================

# API Version
API_VERSION=v1

# Application name
APP_NAME=L.O.V.E. Observer API

# Application description
APP_DESCRIPTION=Emotional state persistence and context retrieval
