# pin: python – https://hub.docker.com/_/python
FROM python:3.12.8-bookworm
# pin: uv – https://github.com/astral-sh/uv/pkgs/container/uv
COPY --from=ghcr.io/astral-sh/uv:0.5 /uv /bin/uv

WORKDIR /app

# Install system dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
  curl \
  gcc \
  build-essential \
  pkg-config \
  libpq-dev \
  && rm -rf /var/lib/apt/lists/*

# Enable bytecode compilation
ENV UV_COMPILE_BYTECODE=1
ENV UV_LINK_MODE=copy

# Install Python dependencies
COPY pyproject.toml uv.lock ./
RUN uv sync --frozen --no-install-project --no-dev --group observer

# Copy application code from module subdir
COPY observer/app/ app/
COPY infra/lib/python/ common/
COPY observer/alembic.ini .
COPY observer/migrations/ migrations/
COPY observer/scripts/ scripts/
COPY observer/data/ data/
COPY observer/start.sh .

# Model Caching (Bake into image)
ENV HF_HOME=/app/models_cache
RUN mkdir -p /app/models_cache
ARG HF_TOKEN
# Use the venv's python to run the script
RUN HF_TOKEN=$HF_TOKEN /app/.venv/bin/python scripts/download_models.py

# Force offline mode for runtime
ENV HF_HUB_OFFLINE=1

# Environment variables
ENV PYTHONUNBUFFERED=1
ENV PYTHONPATH="/app:/app/common"
ENV PATH="/app/.venv/bin:$PATH"

# Expose port
EXPOSE 8000

# Healthcheck
HEALTHCHECK --interval=30s --timeout=30s --start-period=10s --retries=3 \
  CMD curl -f http://localhost:8000/health || exit 1

# Startup script permissions
RUN chmod +x start.sh

# Command
CMD ["./start.sh"]
