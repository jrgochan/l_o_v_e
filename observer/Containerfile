FROM python:3.12-bookworm

WORKDIR /app

# Install system dependencies
# libpq-dev is required for psycopg2 build if source build needed, 
# but we use psycopg2-binary. However asyncpg might need it too or basic gcc.
# git is often needed for some pip installs or tools.
RUN apt-get update && apt-get install -y --no-install-recommends \
  curl \
  gcc \
  build-essential \
  pkg-config \
  libpq-dev \
  && rm -rf /var/lib/apt/lists/*

# Install Python dependencies
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy application code
COPY app/ app/
COPY alembic.ini .
COPY migrations/ migrations/
COPY scripts/ scripts/
COPY data/ data/

# Model Caching (Bake into image)
ENV HF_HOME=/app/models_cache
RUN mkdir -p /app/models_cache
ARG HF_TOKEN
RUN HF_TOKEN=$HF_TOKEN python scripts/download_models.py

# Force offline mode for runtime (uses baked cache)
ENV HF_HUB_OFFLINE=1

# Environment variables
ENV PYTHONUNBUFFERED=1
ENV PYTHONPATH=/app

# Expose port
EXPOSE 8000

# Healthcheck
HEALTHCHECK --interval=30s --timeout=30s --start-period=10s --retries=3 \
  CMD curl -f http://localhost:8000/health || exit 1

# Command
# Copy startup script
COPY start.sh .
RUN chmod +x start.sh

# Command
CMD ["./start.sh"]
