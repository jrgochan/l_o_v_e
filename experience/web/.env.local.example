# L.O.V.E. Experience - Web Version
# Environment Configuration

# Observer API
# Provides real-time emotional state from stored emotional history
NEXT_PUBLIC_OBSERVER_URL=http://localhost:8000

# Listener API
# Analyzes text/audio input to extract VAC emotional coordinates
NEXT_PUBLIC_LISTENER_URL=http://localhost:8002

# Feature Flags
# Enable/disable Observer API polling
NEXT_PUBLIC_ENABLE_OBSERVER_POLLING=false

# User ID for Observer polling (when enabled)
NEXT_PUBLIC_USER_ID=demo-user

# Polling interval in milliseconds (default: 5000 = 5 seconds)
NEXT_PUBLIC_POLLING_INTERVAL=5000
