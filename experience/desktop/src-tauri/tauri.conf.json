{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "L.O.V.E. Experience",
  "version": "0.1.0",
  "identifier": "com.love.experience.desktop",
  "build": {
    "beforeDevCommand": "npm run dev --workspace=web",
    "beforeBuildCommand": "npm run build --workspace=web",
    "devUrl": "http://localhost:3000",
    "frontendDist": "../../web/out"
  },
  "app": {
    "windows": [
      {
        "title": "L.O.V.E. Experience",
        "width": 1200,
        "height": 800
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
