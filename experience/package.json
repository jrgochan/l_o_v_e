{
  "name": "@love/experience-monorepo",
  "version": "1.0.0",
  "description": "L.O.V.E. Experience Module - Monorepo with shared code and web version",
  "private": true,
  "workspaces": [
    "shared",
    "web",
    "desktop"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace=web",
    "dev:web:webpack": "npm run dev --workspace=web -- --webpack",
    "build:shared": "npm run build --workspace=shared",
    "build:web": "npm run build --workspace=web",
    "build:desktop": "npm run build --workspace=desktop",
    "build:all": "npm run build --workspaces",
    "build": "npm run build:all",
    "test:shared": "jest --projects shared",
    "test": "npm test --workspaces",
    "clean": "rm -rf shared/dist shared/node_modules web/node_modules web/.next node_modules",
    "reinstall": "npm run clean && npm install",
    "lint": "npm run lint --workspaces",
    "lint:fix": "npm run lint --workspaces -- --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc -b"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "typescript": "^5.3.0"
  },
  "keywords": [
    "vac",
    "emotion",
    "visualization",
    "soul-sphere",
    "love"
  ],
  "author": "L.O.V.E. Project",
  "license": "UNLICENSED"
}
