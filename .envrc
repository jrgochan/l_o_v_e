# L.O.V.E. Stack — direnv configuration
# Automatically activates the project venv and sets env vars.
#
# Install direnv: brew install direnv
# Then run: direnv allow
#
# Docs: https://direnv.net

# ── Virtual environment ─────────────────────────────────────
# Use the root .venv managed by uv
if [ -d ".venv" ]; then
    export VIRTUAL_ENV="$(pwd)/.venv"
    PATH_add ".venv/bin"
fi

# ── Environment variables ───────────────────────────────────
# Source base env if present (non-sensitive defaults)
if [ -f "infra/configs/base.env" ]; then
    dotenv "infra/configs/base.env"
fi

# Source local overrides (gitignored)
if [ -f ".env" ]; then
    dotenv ".env"
fi

# ── Project root ────────────────────────────────────────────
export PROJECT_ROOT="$(pwd)"
export LOVE_STACK=true

# ── Shell completions ───────────────────────────────────────
if [ -f "infra/lib/completions.sh" ]; then
    source_env "infra/lib/completions.sh"
fi

# ── Tool versions ───────────────────────────────────────────
# Ensure correct Python/Node on PATH
if [ -f ".python-version" ]; then
    use python
fi

if [ -f ".node-version" ]; then
    use node
fi
