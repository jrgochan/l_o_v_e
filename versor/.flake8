# Flake8 configuration for L.O.V.E. platform
# PEP 8 style guide enforcement
#
# This is the canonical configuration maintained in infra/configs/
# It is distributed to modules during setup

[flake8]
max-line-length = 100
max-complexity = 15
exclude = 
    .git,
    __pycache__,
    .venv,
    venv,
    migrations,
    .pytest_cache,
    htmlcov,
    build,
    dist,
    *.egg-info

# Error codes to ignore
# E203: whitespace before ':' (conflicts with black)
# E501: line too long (handled by black)
# W503: line break before binary operator (PEP 8 updated)
ignore = 
    E203,
    E501,
    W503,
    
# Per-file ignores
# __init__.py: F401,F403 - Unused imports in __init__ are often intentional
per-file-ignores =
    __init__.py:F401,F403

# Complexity warning
warn-symbols = 
    C901  # Complexity warning

# Enable specific checks
select = E,W,F,C,N

# Statistics
statistics = True
count = True
